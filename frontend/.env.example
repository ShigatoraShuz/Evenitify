# Eventify Frontend Environment Configuration

# API Mode: Set to 'true' to use mock data (default), 'false' for real backend
VITE_USE_MOCKS=true

# Backend API base URL (only used when VITE_USE_MOCKS=false)
VITE_API_BASE_URL=http://localhost:5000/api

# Supabase configuration (frontend-safe anon key only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Application
VITE_APP_NAME=Eventify
VITE_APP_VERSION=1.0.0
